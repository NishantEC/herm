# herm — terraform variables
# Generated by `herm init` from ~/.config/herm/config.toml.
# Never commit a populated copy of this file.

project_id      = "<YOUR_GCP_PROJECT_ID>"
region          = "us-central1"
zone            = "us-central1-a"
machine_type    = "e2-small"
disk_size_gb    = 10
hostname        = "herm-vm"
tailnet_owner_tag = "tag:<YOUR_TAILSCALE_USERNAME>"
# Secret value injected at apply time by herm CLI; do NOT hardcode here.
# tailscale_auth_key = ""
