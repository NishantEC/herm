#!/usr/bin/env bash
# herm — AI agent workstation on GCP.
# Dispatcher. Each subcommand is its own file under cli/commands/.

set -euo pipefail

HERM_BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# Resolve through symlinks (Makefile install creates a symlink):
if [[ -L ${BASH_SOURCE[0]} ]]; then
  HERM_BIN_DIR="$(cd "$(dirname "$(readlink "${BASH_SOURCE[0]}")")" && pwd)"
fi
HERM_REPO_ROOT="$(cd "$HERM_BIN_DIR/.." && pwd)"
export HERM_REPO_ROOT

# shellcheck source=../cli/lib.sh
source "$HERM_REPO_ROOT/cli/lib.sh"

usage() {
  cat <<'EOF'
herm — AI agent workstation on GCP

USAGE:
  herm <command> [args...]

LIFECYCLE
  init               One-time: configure ~/.config/herm/config.toml, enable APIs, create state bucket
  up                 terraform apply: provision VM, join tailnet
  down               terraform destroy of VM + ephemeral resources (disk + backup survive)
  nuke               Destroy everything including persistent disk and backup bucket
  status             Show VM status, tailnet reachability, last backup time

DAY-TO-DAY
  ssh                tailscale ssh herm@<hostname>
  logs <unit>        Tail journald for a systemd unit on the VM (hermes-agent, herm-backup, ...)
  open <target>      Open one of the VM's surfaces in the default browser
  qr                 Print a terminal QR code with the gateway URL + bearer token

AUTH
  login <provider>   Run an interactive OAuth/device-code flow on the VM
                     providers: claude | gh | gemini | codex | opencode | goose | all

SKILLS
  skills <subcommand>   Manage the agent's skills (list | sync | enable | disable)

MAINTENANCE
  rotate [target]    Rotate the Hermes API server token (target: hermes — default)
  upgrade            Snapshot disk, pull latest versions, restart, verify, auto-rollback on failure
  backup [now|list]  Trigger an immediate GCS rsync, or list dated backup folders
  restore <YYYY-MM-DD>  Restore /home/herm from a dated backup snapshot
  console            Open the GCP console page for this VM in the default browser

  help               Show this message

See docs/ for the threat model, security controls, cost breakdown, skills, rotation, and troubleshooting.
EOF
}

cmd="${1:-help}"
shift || true

case "$cmd" in
  help|-h|--help)
    usage
    ;;
  init|up|down|nuke|status|ssh|login|open|qr|rotate|upgrade|backup|restore|logs|console|skills)
    cmd_file="$HERM_REPO_ROOT/cli/commands/${cmd}.sh"
    if [[ ! -f $cmd_file ]]; then
      herm::die "subcommand file missing: $cmd_file"
    fi
    # shellcheck disable=SC1090
    source "$cmd_file"
    "herm::cmd::$cmd" "$@"
    ;;
  *)
    herm::err "unknown command: $cmd"
    usage
    exit 2
    ;;
esac
